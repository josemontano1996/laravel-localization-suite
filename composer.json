{
    "name": "josemontano1996/laravel-localization-suite",
    "autoload": {
        "psr-4": {
            "Josemontano1996\\LaravelLocalizationSuite\\": "src/"
        },
        "files": [
            "src/helpers.php",
            "src/Support/phpdocs.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Jose Manuel Montano Mengual",
            "email": "jm3develop@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.26",
        "pestphp/pest": "^4.2",
        "orchestra/testbench": "^10.8",
        "phpstan/phpstan": "^2.1"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Josemontano1996\\LaravelLocalizationSuite\\LocalizationServiceProvider"
            ],
            "aliases": {
                "Localization": "Josemontano1996\\LaravelLocalizationSuite\\Facades\\Localization"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint --parallel",
        "analyse": "phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}